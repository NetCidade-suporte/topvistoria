---
import siteData from "../data/siteData.json";

const { empresa_nome, empresa_whatsapp } = siteData.configuracoes;
const whatsappLink = `https://wa.me/${empresa_whatsapp}?text=Ol%C3%A1%21+Gostaria+de+saber+mais+informa%C3%A7%C3%B5es+e+agendar+uma+Vistoria+Cautelar.`;
---

<header class="main-header">
  <div class="container header-container">
    <a href="#" class="logo-box" aria-label="Top Vistorias Home">
      <img
        src="/assets/images/LOGO-BRANCA.webp"
        alt="Top Vistorias Logo"
        class="logo-img"
        width="320"
        height="96"
      />
    </a>

    <nav class="desktop-nav">
      <a href="#servicos" class="nav-link">Serviços</a>
      <a href="#beneficios" class="nav-link">Vantagens</a>
      <a href="#faq" class="nav-link">Dúvidas</a>
      <a href="#localizacao" class="nav-link">Contato</a>
    </nav>

    <div class="cta-box">
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-whatsapp header-btn"
      >
        <svg
          class="btn-icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.37 5.054L2 22l5.132-1.347a9.936 9.936 0 0 0 4.877 1.28h.005c5.505 0 9.989-4.478 9.99-9.984A10.015 10.015 0 0 0 12.012 2zm5.72 14.158c-.246.693-1.424 1.306-1.95 1.36-.492.052-.98.243-3.137-.624-2.6-.967-4.244-3.626-4.374-3.797-.13-.172-1.056-1.403-1.056-2.678 0-1.275.666-1.902.903-2.148.236-.245.513-.306.684-.306.17 0 .341.002.49.01.15.007.35-.027.549.453.2.48.682 1.663.742 1.785.06.121.099.263.018.423-.08.16-.12.26-.24.4-.12.14-.252.312-.36.419-.12.12-.244.251-.106.49.138.238.614 1.011 1.317 1.637.904.805 1.66 1.052 1.897 1.171.237.119.375.101.514-.06.14-.16.598-.697.757-.936.16-.239.319-.2.537-.12.219.08 1.385.653 1.624.772.239.119.398.178.458.28.06.1.06.582-.186 1.275z"
          ></path>
        </svg>
        <span>Agendar Agora</span>
      </a>
    </div>
  </div>
</header>

<style>
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(8, 15, 31, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo-box {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-img {
    height: 68px;
    width: auto;
    display: block;
    transition: all 0.3s ease;
  }

  .logo-box:hover .logo-img {
    transform: scale(1.03);
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: var(--transition-fast);
    position: relative;
    padding: 8px 0;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent-yellow);
    transition: var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--text-main);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .header-btn {
    padding: 10px 20px;
    font-size: 0.85rem;
  }

  .btn-icon {
    margin-right: 4px;
  }

  /* Mudança no cabeçalho ao rolar */
  .main-header.scrolled {
    background: rgba(8, 15, 31, 0.9);
    height: 70px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .main-header.scrolled .header-container {
    height: 70px;
  }

  .main-header.scrolled .logo-img {
    height: 54px;
  }

  /* Responsividade */
  @media (max-width: 768px) {
    .desktop-nav {
      display: none; /* Em mobile, foca no botão direto do WhatsApp */
    }
    .logo-img {
      height: 54px;
    }
  }
</style>

<script>
  // Adiciona classe quando rolar a página
  window.addEventListener("scroll", () => {
    const header = document.querySelector(".main-header");
    if (header) {
      if (window.scrollY > 50) {
        header.classList.add("scrolled");
      } else {
        header.classList.remove("scrolled");
      }
    }
  });
</script>
