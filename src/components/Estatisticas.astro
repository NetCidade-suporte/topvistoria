---
import siteData from "../data/siteData.json";

const { empresa_nome } = siteData.configuracoes;
---

<section class="estatisticas-section">
  <!-- Efeito de partículas de fundo ou grid sutil -->
  <div class="grid-overlay"></div>

  <div class="container estatisticas-container grid">
    <div class="estatistica-item glass-card stat-card">
      <div class="number-box">
        <span class="stat-number">17</span>
        <span class="plus-sign">+</span>
      </div>
      <div class="stat-content">
        <h4>Anos de Experiência</h4>
        <p>Expertise consolidada no mercado automotivo</p>
      </div>
    </div>

    <div class="estatistica-item glass-card stat-card">
      <div class="number-box">
        <span class="stat-number">100</span>
        <span class="plus-sign">+</span>
      </div>
      <div class="stat-content">
        <h4>Unidades no Brasil</h4>
        <p>Uma rede de confiança de ponta a ponta do país</p>
      </div>
    </div>

    <div class="estatistica-item glass-card stat-card">
      <div class="number-box">
        <span class="stat-number">200</span>
        <span class="stat-letter">K+</span>
      </div>
      <div class="stat-content">
        <h4>Vistorias Anuais</h4>
        <p>Milhares de motoristas que rodam com tranquilidade</p>
      </div>
    </div>

    <div class="estatistica-item glass-card stat-card">
      <div class="number-box">
        <span class="stat-number">99.5</span>
        <span class="stat-letter">%</span>
      </div>
      <div class="stat-content">
        <h4>Aprovação dos Clientes</h4>
        <p>Qualidade certificada e avaliações excelentes</p>
      </div>
    </div>
  </div>
</section>

<style>
  .estatisticas-section {
    position: relative;
    padding: 100px 0;
    background: linear-gradient(
        rgba(8, 15, 31, 0.86) 0%,
        rgba(8, 15, 31, 0.9) 100%
      )
      no-repeat center center;
    background-size: cover;
    background-attachment: fixed;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    overflow: hidden;
  }

  .grid-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.01) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 1;
  }

  .estatisticas-container {
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    position: relative;
    z-index: 2;
  }

  .estatistica-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .number-box {
    display: flex;
    align-items: baseline;
    justify-content: center;
    margin-bottom: 12px;
    font-family: var(--font-family);
  }

  .stat-number {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    color: var(--color-accent-yellow);
    background: linear-gradient(135deg, #f59e0b, #ffba08);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .plus-sign,
  .stat-letter {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent-yellow);
    margin-left: 2px;
  }

  .stat-content h4 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-white);
    margin-bottom: 6px;
  }

  .stat-content p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.4;
    max-width: 220px;
    margin: 0 auto;
  }

  /* Responsividade */
  @media (max-width: 992px) {
    .estatisticas-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
  }

  @media (max-width: 576px) {
    .estatisticas-container {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .stat-number {
      font-size: 3rem;
    }
  }

  .stat-card {
    padding: 30px 20px;
    background: rgba(21, 34, 68, 0.15) !important;
    border: 1px solid rgba(255, 255, 255, 0.04) !important;
    border-radius: var(--radius-md);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .stat-card:hover {
    background: rgba(21, 34, 68, 0.3) !important;
    border-color: rgba(59, 130, 246, 0.25) !important;
    transform: translateY(-5px);
    box-shadow:
      0 15px 30px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(59, 130, 246, 0.1);
  }
</style>
