---
import siteData from '../data/siteData.json';

const { empresa_whatsapp, empresa_whatsapp_formatado } = siteData.configuracoes;
const whatsappLink = `https://wa.me/${empresa_whatsapp}?text=Ol%C3%A1%21+Gostaria+de+saber+mais+informa%C3%A7%C3%B5es+e+agendar+uma+Vistoria+Cautelar.`;
---

<div class="whatsapp-wrapper" id="whatsapp-wrapper">
  <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="whatsapp-btn" aria-label="Fale conosco no WhatsApp">
    <div class="pulse-ring"></div>
    <div class="pulse-ring-slow"></div>
    <svg class="whatsapp-icon" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
      <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
    </svg>
  </a>
  <div class="whatsapp-tooltip">
    <span class="tooltip-title">Precisa de Laudo?</span>
    <span class="tooltip-text">Agende pelo WhatsApp</span>
  </div>
</div>

<style>
  .whatsapp-wrapper {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 9999;
    display: flex;
    align-items: center;
  }

  .whatsapp-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background-color: var(--color-accent-green, #10b981);
    border-radius: 50%;
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4);
    transition: all 0.3s ease;
  }

  .whatsapp-icon {
    width: 32px;
    height: 32px;
    fill: #ffffff;
    z-index: 2;
  }

  .whatsapp-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 24px rgba(16, 185, 129, 0.6);
  }

  /* Animações de Pulsar */
  .pulse-ring, .pulse-ring-slow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background-color: var(--color-accent-green, #10b981);
    z-index: 1;
    opacity: 0.4;
  }

  .pulse-ring {
    animation: whatsapp-pulse 2s infinite ease-out;
  }

  .pulse-ring-slow {
    animation: whatsapp-pulse 2s infinite ease-out 0.8s;
  }

  @keyframes whatsapp-pulse {
    0% {
      transform: scale(1);
      opacity: 0.4;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  /* Tooltip */
  .whatsapp-tooltip {
    position: absolute;
    right: 75px;
    background: #0f172a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff;
    padding: 8px 16px;
    border-radius: 8px;
    white-space: nowrap;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.5);
    opacity: 0;
    transform: translateX(20px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .whatsapp-tooltip::after {
    content: '';
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
    width: 10px;
    height: 10px;
    background: #0f172a;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .tooltip-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-accent-yellow, #f59e0b);
  }

  .tooltip-text {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  /* Mostrar tooltip após um pequeno delay ou hover */
  .whatsapp-wrapper:hover .whatsapp-tooltip {
    opacity: 1;
    transform: translateX(0);
  }

  /* Tooltip aparece automaticamente no carregamento */
  .whatsapp-wrapper.show-tooltip .whatsapp-tooltip {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .whatsapp-wrapper {
      bottom: 20px;
      right: 20px;
    }
    .whatsapp-btn {
      width: 50px;
      height: 50px;
    }
    .whatsapp-icon {
      width: 26px;
      height: 26px;
    }
    .whatsapp-tooltip {
      display: none; /* Esconder tooltip em telas pequenas para evitar poluição visual */
    }
  }
</style>

<script>
  // Mostrar o tooltip automaticamente após 3 segundos
  setTimeout(() => {
    const wrapper = document.getElementById('whatsapp-wrapper');
    if (wrapper) {
      wrapper.classList.add('show-tooltip');
      // Esconder novamente após 6 segundos
      setTimeout(() => {
        wrapper.classList.remove('show-tooltip');
      }, 6000);
    }
  }, 3000);
</script>
