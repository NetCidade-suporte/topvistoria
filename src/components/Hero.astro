---
import siteData from '../data/siteData.json';

const { hero } = siteData.secoes;
const { empresa_whatsapp } = siteData.configuracoes;
const whatsappLink = `https://wa.me/${empresa_whatsapp}?text=Ol%C3%A1%21+Gostaria+de+saber+mais+informa%C3%A7%C3%B5es+e+agendar+uma+Vistoria+Cautelar.`;
---

<section class="hero-section" id="home">
  <div class="hero-bg-overlay"></div>
  
  <div class="container hero-container">
    <div class="hero-content">
      <span class="badge-top">Vistoria Cautelar Profissional</span>
      <h1 class="hero-title" set:html={hero.titulo}></h1>
      <p class="hero-subtitle">{hero.subtitulo}</p>
      
      <div class="hero-actions">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary hero-btn">
          <span>{hero.cta_texto}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#servicos" class="btn btn-secondary hero-btn">Ver Detalhes</a>
      </div>

      <!-- Trust Badges -->
      <div class="trust-badges">
        <div class="badge-item">
          <svg class="badge-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span>Laudo Aprovado DETRAN</span>
        </div>
        <div class="badge-item">
          <svg class="badge-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>Empresa Credenciada (ECV)</span>
        </div>
        <div class="badge-item">
          <svg class="badge-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <span>Agendamento Rápido</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    padding: 160px 0 120px 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-image: 
      linear-gradient(rgba(8, 15, 31, 0.76) 0%, rgba(8, 15, 31, 0.88) 100%), 
      url("/assets/images/toplondrina-hero.webp");
    background-repeat: no-repeat;
    background-position: center center;
    background-size: cover;
    background-attachment: scroll, fixed;
  }

  .hero-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
      radial-gradient(circle at 10% 20%, rgba(59, 130, 246, 0.15) 0%, transparent 50%),
      linear-gradient(rgba(255, 255, 255, 0.003) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.003) 1px, transparent 1px);
    background-size: 100% 100%, 40px 40px, 40px 40px;
    z-index: 1;
    pointer-events: none;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: flex-start;
    align-items: center;
  }

  .hero-content {
    width: 100%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    padding: 20px 0;
  }

  .hero-title {
    font-size: 3.8rem;
    font-weight: 800;
    color: var(--text-white);
    line-height: 1.15;
    margin-bottom: 24px;
    letter-spacing: -1.5px;
    text-align: left;
  }

  .hero-title :global(strong) {
    color: var(--color-accent-yellow);
    background: linear-gradient(90deg, #f59e0b, #ffba08);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 1.3rem;
    color: #cbd5e1;
    line-height: 1.65;
    margin-bottom: 40px;
    max-width: 680px;
    text-align: left;
  }

  .hero-actions {
    display: flex;
    gap: 20px;
    margin-bottom: 48px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .hero-btn {
    padding: 16px 36px;
    font-size: 1rem;
  }

  /* Trust Badges */
  .trust-badges {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
    justify-content: flex-start;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 32px;
    width: 100%;
  }

  .badge-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
    transition: all 0.3s ease;
  }

  .badge-item:hover {
    transform: translateY(-2px);
    color: var(--color-accent-yellow);
  }

  .badge-icon {
    color: var(--color-accent-green);
    flex-shrink: 0;
  }

  /* Responsividade */
  @media (max-width: 992px) {
    .hero-title {
      font-size: 3rem;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 140px 0 80px 0;
      background-attachment: scroll;
    }

    .hero-content {
      align-items: center;
      text-align: center;
    }

    .hero-title {
      font-size: 2.2rem;
      letter-spacing: -0.5px;
      text-align: center;
    }

    .hero-subtitle {
      font-size: 1.05rem;
      margin-bottom: 30px;
      text-align: center;
    }

    .hero-actions {
      flex-direction: column;
      gap: 12px;
      width: 100%;
      justify-content: center;
    }

    .hero-btn {
      width: 100%;
    }

    .trust-badges {
      gap: 20px;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
  }
</style>
