---
import siteData from '../data/siteData.json';

const { configuracoes } = siteData;
const whatsappLink = `https://wa.me/${configuracoes.empresa_whatsapp}?text=Ol%C3%A1%21+Gostaria+de+saber+mais+informa%C3%A7%C3%B5es+e+agendar+uma+Vistoria+Cautelar.`;
---

<section class="localizacao-section" id="localizacao">
  <div class="container localizacao-container grid">
    <div class="localizacao-info">
      <span class="badge-top">Onde Estamos</span>
      <h2 class="localizacao-title">Venha Nos Visitar</h2>
      <p class="localizacao-desc">
        Nossa unidade em Londrina está de portas abertas para oferecer o melhor atendimento e garantir o laudo cautelar que você precisa.
      </p>

      <div class="info-items">
        <div class="info-item">
          <div class="info-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="info-text-box">
            <h4>Endereço</h4>
            <p>{configuracoes.empresa_endereco}</p>
            <p>CEP: {configuracoes.empresa_cep}</p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </div>
          <div class="info-text-box">
            <h4>Horário de Atendimento</h4>
            <p>{configuracoes.horario_atendimento}</p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div class="info-text-box">
            <h4>Contatos Rápidos</h4>
            <p><strong>WhatsApp:</strong> <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="link-highlight">{configuracoes.empresa_whatsapp_formatado}</a></p>
            <p><strong>E-mail:</strong> <a href={`mailto:${configuracoes.empresa_email}`} class="link-highlight">{configuracoes.empresa_email}</a></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Mapa Interativo -->
    <div class="map-wrapper glass-card">
      <iframe 
        src={`https://maps.google.com/maps?q=${configuracoes.empresa_latitude},${configuracoes.empresa_longitude}&t=m&z=16&output=embed&iwloc=near`}
        class="map-iframe"
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        title="Localização Top Vistorias Londrina"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .localizacao-section {
    padding: 100px 0;
    position: relative;
    background: 
      linear-gradient(rgba(8, 15, 31, 0.88) 0%, rgba(8, 15, 31, 0.93) 100%), 
      url('/assets/images/toplondrina-07.webp') no-repeat center center;
    background-size: cover;
    background-attachment: fixed;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .localizacao-container {
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: 60px;
  }

  .localizacao-title {
    font-size: 2.2rem;
    color: var(--text-white);
    margin-bottom: 16px;
  }

  .localizacao-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 36px;
  }

  /* Items de Informação */
  .info-items {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .info-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .info-icon-box {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background-color: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-secondary);
    flex-shrink: 0;
  }

  .info-text-box h4 {
    font-size: 1.1rem;
    color: var(--text-white);
    margin-bottom: 4px;
  }

  .info-text-box p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .link-highlight {
    color: var(--color-accent-yellow);
    font-weight: 600;
    transition: var(--transition-fast);
  }

  .link-highlight:hover {
    color: var(--text-white);
  }

  /* Container do Mapa */
  .map-wrapper {
    width: 100%;
    height: 450px;
    overflow: hidden;
    padding: 10px;
    border-radius: var(--radius-md);
  }

  .map-iframe {
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: calc(var(--radius-md) - 10px);
    background: #080f1f;
  }

  /* Responsividade */
  @media (max-width: 992px) {
    .localizacao-container {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    
    .map-wrapper {
      height: 350px;
    }
  }
</style>
